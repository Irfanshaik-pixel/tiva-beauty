{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "createdAt": { "type": "integer" }
      },
      "required": ["email", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "An ecommerce order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"] },
        "createdAt": { "type": "integer" },
        "shippingInfo": {
          "type": "object",
          "properties": {
            "firstName": { "type": "string" },
            "lastName": { "type": "string" },
            "street": { "type": "string" },
            "city": { "type": "string" },
            "state": { "type": "string" },
            "pincode": { "type": "string" },
            "country": { "type": "string" }
          }
        }
      },
      "required": ["userId", "total", "status", "createdAt", "shippingInfo"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Users collection"
    },
    "orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Orders collection"
    }
  }
}
